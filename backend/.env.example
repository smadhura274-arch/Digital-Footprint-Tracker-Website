PORT=5000
NODE_ENV=development
JWT_SECRET=your_jwt_secret_key_here

# MongoDB Atlas connection string
# Replace <username>, <password>, and <cluster> with your Atlas credentials
# Get this from: Atlas > Your Cluster > Connect > Drivers
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/digital_footprint_tracker?retryWrites=true&w=majority&appName=DigitalFootprintTracker

# Optional
CLIENT_URL=http://127.0.0.1:5500
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
